#!/bin/bash -x

function createSession
{
    local session="$1"; shift
    local dir="$1"; shift

    # tmux new-session -d -s "$session" -n "$session" -t "${session}-group" -c "$dir"
    tmux new-session -d -s "$session" -n "$session" -c "$dir"
}

function addWindow
{
    local session="$1"; shift
    local name="$1"; shift
    local dir="$1"; shift

    local numWindows=$(tmux list-windows -t "$session" | wc -l)
    tmux new-window -d -t "$session:$numWindows" -n "$name" -c "$dir"
}

# PDC session
PDC_ROOT="$HOME/work/cba/repos/pdc"
createSession pdc "$PDC_ROOT"
addWindow pdc pdc-main "$PDC_ROOT/pdc-main"

# PJ Listener session
PJ_ROOT="$HOME/work/cba/repos/pj"
createSession pj "$PJ_ROOT"
addWindow pj pj-main "$PJ_ROOT/pj-main"

# Data Assurance
PDA_ROOT="$HOME/work/cba/repos/pda"
createSession pda "$PDA_ROOT"
addWindow pda pda-main "$PDA_ROOT/pda-main"

# Other repos
REPOS_ROOT="$HOME/work/cba/repos"
createSession repos "$REPOS_ROOT"
addWindow repos heeler-main "$REPOS_ROOT/misc/heeler-main"

# Scratch session
createSession scratch "$HOME"
addWindow scratch dev-env "$HOME/dev-env"
addWindow scratch emacs "$HOME/.emacs.d"
addWindow scratch downloads "$HOME/work/Downloads"
#addWindow scratch heeler-ai "$PDC_ROOT/payments-data-cloud-pj-listener"
